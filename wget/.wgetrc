# Preserve original file modification dates instead of using download time
timestamping = on

# Prevent accidentally downloading an entire website when using -r
no_parent = on

# Default read timeout is 15 minutes — way too long for a hung connection
timeout = 60

# Default is 20 retries — 3 is enough to handle transient errors without wasting time
tries = 3

# Retry even on connection refused — the server might be restarting
retry_connrefused = on

# Use the final URL's filename after redirects (not the redirect URL's name)
trust_server_names = on

# Auto-add .html/.css extensions when the server says the content type but the URL lacks one
adjust_extension = on

# wget is a tool, not a search engine crawler — robots.txt doesn't apply to manual downloads
robots = off

# Show server response headers — useful for debugging download issues
server_response = on
