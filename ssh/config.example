# Persist connections in macOS Keychain so you don't re-enter passphrases
Host *
	AddKeysToAgent yes
	UseKeychain yes
	IdentityFile ~/.ssh/id_ed25519

# GitHub — personal account
Host github.com
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_ed25519

# GitHub — work account (if using a separate key)
# Host github-work
# 	HostName github.com
# 	User git
# 	IdentityFile ~/.ssh/id_ed25519_work
