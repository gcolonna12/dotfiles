# Machine-specific config (user identity, profile switching, credentials).
# Generated by install.sh — not tracked in git.
[include]
	path = ~/.gitconfig.local

[alias]

	# Compact log with graph — see branch topology at a glance
	l = log --pretty=oneline -n 20 --graph --abbrev-commit

	# Short status — less noise than the default verbose output
	s = status -s

	# Diff with stats — clears screen first so you see the diff clean
	d = !"git diff-index --quiet HEAD -- || clear; git --no-pager diff --patch-with-stat"

	# Diff N commits back: `git di 3` shows diff from 3 commits ago
	di = !"d() { git diff --patch-with-stat HEAD~$1; }; git diff-index --quiet HEAD -- || clear; d"

	# Pull with submodules — without --recurse-submodules, submodules stay stale
	p = pull --recurse-submodules

	# Clone with submodules — same reason as above
	c = clone --recursive

	# Stage everything and commit — one step for quick saves
	ca = !git add ':(exclude,attr:builtin_objectmode=160000)' && git commit -av

	# Checkout or create a branch — no need to remember if it exists
	go = "!f() { git checkout -b \"$1\" 2> /dev/null || git checkout \"$1\"; }; f"

	# Quick inspection of tags, branches, and remotes
	tags = tag -l
	branches = branch --all
	remotes = remote --verbose

	# Handy when you forget what aliases you have
	aliases = config --get-regexp alias

	# Amend last commit without changing the message — for "oops, forgot a file"
	amend = commit --amend --reuse-message=HEAD

	# Credit a co-author on the latest commit
	credit = "!f() { git commit --amend --author \"$1 <$2>\" -C HEAD; }; f"

	# Interactive rebase last N commits: `git reb 5`
	reb = "!r() { git rebase -i HEAD~$1; }; r"

	# Find which branches contain a given commit SHA
	fb = "!f() { git branch -a --contains $1; }; f"

	# Find which tags contain a given commit SHA
	ft = "!f() { git describe --always --contains $1; }; f"

	# Search commit history for code changes containing a string
	fc = "!f() { git log --pretty=format:'%C(yellow)%h  %Cblue%ad  %Creset%s%Cgreen  [%cn] %Cred%d' --decorate --date=short -S$1; }; f"

	# Search commit messages for a string
	fm = "!f() { git log --pretty=format:'%C(yellow)%h  %Cblue%ad  %Creset%s%Cgreen  [%cn] %Cred%d' --decorate --date=short --grep=$1; }; f"

	# Clean up merged branches — keeps your branch list tidy
	dm = "!git branch --merged | grep -v '\\*' | xargs -n 1 git branch -d"

	# Fetch, prune remotes, and delete local branches whose upstream is gone
	cleanup = !git fetch --prune && git checkout main && git branch -vv | grep \": gone]\" | awk '{print $1}' | xargs -r git branch -D

	# Contributors ranked by commit count
	contributors = shortlog --summary --numbered

	# Quick check: which email is git using in this repo?
	whoami = config user.email

[apply]

	# Auto-fix whitespace errors when applying patches
	whitespace = fix

[branch]

	# Most recently worked-on branches appear first in `git branch`
	sort = -committerdate

[core]

	# Global ignore file for OS/editor junk (.DS_Store, .idea, etc.)
	excludesfile = ~/.gitignore

	# Global attributes for diff drivers, merge strategies, etc.
	attributesfile = ~/.gitattributes

	# Flag mixed indentation and trailing whitespace — these cause noisy diffs
	whitespace = space-before-tab,-indent-with-non-tab,trailing-space

	# macOS changes ctime during inode operations, causing false dirty files during rebase
	trustctime = false

	# Prevents files with non-ASCII names (umlauts, kanji, etc.) from showing as unversioned
	precomposeunicode = false

	# Caches untracked file state — makes `git status` faster on large repos
	untrackedCache = true

[color]

	ui = auto

[color "branch"]

	current = yellow reverse
	local = yellow
	remote = green

[color "diff"]

	meta = yellow bold
	frag = magenta bold
	old = red
	new = green

[color "status"]

	added = yellow
	changed = green
	untracked = cyan

[diff]

	# Detect file copies as well as renames — otherwise copies show as new files
	renames = copies

[diff "bin"]

	# Show hex diff for binary files instead of "binary files differ"
	textconv = hexdump -v -C

[help]

	# Auto-correct and run mistyped commands after 0.1s (e.g., `git stauts` → `git status`)
	autocorrect = 1

[merge]

	# Include one-line summaries of merged commits in merge commit messages
	log = true

[push]

	# Only push the current branch — prevents accidentally pushing other branches
	default = simple
	# Push annotated tags along with branches — no more forgetting `git push --tags`
	followTags = true

# URL shorthands: `git clone gh:user/repo` instead of the full SSH URL
[url "git@github.com:"]

	insteadOf = "gh:"
	pushInsteadOf = "github:"
	pushInsteadOf = "git://github.com/"

[url "git://github.com/"]

	insteadOf = "github:"

[url "git@gist.github.com:"]

	insteadOf = "gst:"
	pushInsteadOf = "gist:"
	pushInsteadOf = "git://gist.github.com/"

[url "git://gist.github.com/"]

	insteadOf = "gist:"

[init]

	# New repos default to main — the modern standard
	defaultBranch = main
